# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (Comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_SECRET=your-32-char-minimum-secret-key-here
JWT_EXPIRES_IN=7d

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vinzhub
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false
DB_CONNECTION_LIMIT=20

# Upstash Redis (REST API)
# Get credentials from: https://console.upstash.io
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-u...m

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Discord OAuth2 Configuration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/v1/auth/discord/callback
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Cloudflare R2 Configuration
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.com

# Tokopay Payment Gateway
TOKOPAY_BASE_URL=https://api.tokopay.id
TOKOPAY_MERCHANT_ID=your_merchant_id
TOKOPAY_SECRET_KEY=your_secret_key

# NOWPayments Payment Gateway
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

