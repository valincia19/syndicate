# Monorepo Root GitIgnore

# Node modules
**/node_modules/

# Environment files
**/.env
**/.env.*
!**/.env.example

# Next.js & Build outputs
**/.next/
**/build/
**/dist/
backend/crypto_logos/

# Logs & OS files
*.log
.DS_Store
Thumbs.db

# Exclude non-app directories & local tools/configs
/keyauth/
/design-assets-hub-v2/
/memory/
/.obsidian/
/.vscode/
/.claude/

# Database dumps
*.sql
!/init-db.sql

