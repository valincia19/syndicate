# ============================================
# VALINC SYNDICATE — Discord Bot Environment
# ============================================

# Discord Application Credentials
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Target Guild (Right-click server > Copy Server ID, enable Developer Mode first)
DISCORD_GUILD_ID=

# Channel IDs (Right-click channel > Copy Channel ID)
DISCORD_WELCOME_CHANNEL_ID=
DISCORD_LOG_CHANNEL_ID=

# Backend Internal API
# Docker: http://valinc-backend:5000
# Local:  http://localhost:5000
BACKEND_INTERNAL_URL=http://valinc-backend:5000

# Shared secret for bot → backend internal communication
# Must match INTERNAL_API_SECRET in backend/.env
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# Environment
NODE_ENV=production
